# Set the home directory to /root/ so that "sudo mysql" can find ".my.cnf"
# and Vim doesn't mess up the users's home directory permissions
Defaults always_set_home

# Need this for molly-guard to work inside tmux
Defaults env_keep += SSH_CONNECTION
